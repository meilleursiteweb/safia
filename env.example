# ────────────────────────────────────────────
# .env — Variables d'environnement Safia Rugs
# Copiez ce fichier en .env et remplissez les valeurs
# ────────────────────────────────────────────

# OpenRouter API (openrouter.ai — accès Gemini, Claude, GPT...)
OPENROUTER_API_KEY=sk-or-v1-votre_cle_ici
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ScraperAPI (scraperapi.com — scraping avec rendu JS)
SCRAPER_API_KEY=votre_cle_scraperapi_ici

# Google Sheets (ID dans l'URL du sheet)
SHEETS_ID=16cg8GYbA3nbDHFyAJH91h-XijunD6wV8U27jFXGKzno

# Gmail SMTP (utiliser un App Password, pas votre vrai mot de passe)
# Guide : myaccount.google.com > Sécurité > Mots de passe des applications
GMAIL_USER=votre@gmail.com
GMAIL_PASSWORD=votre_app_password_16_caracteres

# Chemin vers le fichier credentials Google Service Account
GOOGLE_CREDS_FILE=google_credentials.json
